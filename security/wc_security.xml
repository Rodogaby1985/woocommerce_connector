<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_wc_user" model="res.groups">
        <field name="name">WooCommerce Usuario</field>
        <field name="category_id" ref="base.module_category_sales_management"/>
    </record>

    <record id="group_wc_manager" model="res.groups">
        <field name="name">WooCommerce Manager</field>
        <field name="category_id" ref="base.module_category_sales_management"/>
        <field name="implied_ids" eval="[(4, ref('group_wc_user'))]"/>
    </record>
</odoo>
